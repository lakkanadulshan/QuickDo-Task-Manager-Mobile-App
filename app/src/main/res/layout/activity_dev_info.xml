<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#9C27B0">

    <!-- Top Purple Section -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/arrow_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/white" />

    <TextView
        android:id="@+id/tvDevName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Lakkana Dulshan"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvDevRole"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BICT Student"
        android:textColor="#E1BEE7"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvDevName" />

    <TextView
        android:id="@+id/tvDevId"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2023t01908"
        android:textColor="#E1BEE7"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvDevRole" />

    <!-- Middle White Section -->
    <View
        android:id="@+id/whiteBg"
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:layout_marginTop="140dp"
        android:background="@color/white"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Profile Image with Blue Border -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cvAvatarOuter"
        android:layout_width="110dp"
        android:layout_height="110dp"
        app:cardBackgroundColor="#4DD0E1"
        app:cardCornerRadius="55dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toTopOf="@id/whiteBg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/whiteBg">

        <androidx.cardview.widget.CardView
            android:layout_width="104dp"
            android:layout_height="104dp"
            android:layout_gravity="center"
            app:cardCornerRadius="52dp"
            app:cardElevation="0dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/dev" />
        </androidx.cardview.widget.CardView>
    </androidx.cardview.widget.CardView>

    <!-- Follow Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnFollow"
        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
        android:layout_width="130dp"
        android:layout_height="52dp"
        android:layout_marginTop="65dp"
        android:backgroundTint="#80DEEA"
        android:text="Follow"
        android:textAllCaps="false"
        android:textColor="#2D2D2D"
        android:textSize="16sp"
        app:cornerRadius="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/whiteBg"
        app:strokeColor="@color/black"
        app:strokeWidth="1dp" />

    <!-- Stats Row -->
    <LinearLayout
        android:id="@+id/statsRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnFollow">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2065" android:textColor="#4DD0E1" android:textSize="24sp" android:textStyle="bold" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Applications" android:textColor="@color/black" android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="325" android:textColor="#4DD0E1" android:textSize="24sp" android:textStyle="bold" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Followings" android:textColor="@color/black" android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="781" android:textColor="#4DD0E1" android:textSize="24sp" android:textStyle="bold" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Followers" android:textColor="@color/black" android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom Purple Rounded Container -->
    <View
        android:id="@+id/bottomPurple"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bottom_rounded_purple"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/whiteBg" />

    <!-- About Section Box -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/about_box_bg"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/statsRow">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="About Lakkana"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="I am Lakkana Dulshan, currently studying a BICT degree. I am passionate about mobile app development and UI design. I developed QuickDo to help users manage their daily tasks in a simple and efficient way while improving my skills in app design and development."
            android:textColor="@color/black"
            android:textSize="14sp"
            android:lineSpacingExtra="2dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
